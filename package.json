{
  "name": "openspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:chrome": "node scripts/dev-chrome-session.mjs",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:web": "pnpm --filter @openspace/web test",
    "test:web:e2e": "pnpm run test:web:e2e:mock",
    "test:web:e2e:mock": "pnpm --filter @openspace/web test:e2e:mock",
    "test:web:e2e:fullstack": "pnpm --filter @openspace/web test:e2e:fullstack",
    "format": "prettier --write .",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "pnpm": "^10.30.3",
    "prettier": "^3.8.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  }
}
