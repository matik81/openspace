generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  ADMIN
  MEMBER
}

enum UserStatus {
  ACTIVE
  CANCELLED
}

enum WorkspaceStatus {
  ACTIVE
  CANCELLED
}

enum RoomStatus {
  ACTIVE
  CANCELLED
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  REVOKED
}

enum BookingStatus {
  ACTIVE
  CANCELLED
}

enum BookingCancellationReason {
  USER_CANCELLED
  USER_LEFT_WORKSPACE
  ROOM_UNAVAILABLE
  SCHEDULE_INCOMPATIBLE
}

enum BookingCriticality {
  HIGH
  MEDIUM
  LOW
}

enum RateLimitOperationType {
  REGISTER
  CREATE_WORKSPACE
  CREATE_ROOM
  CREATE_INVITATION
  CREATE_BOOKING
}

enum RateLimitSubjectType {
  IP
  USER
}

model User {
  id                     String                   @id @default(uuid()) @db.Uuid
  firstName              String
  lastName               String
  email                  String                   @unique
  passwordHash           String
  status                 UserStatus               @default(ACTIVE)
  cancelledAt            DateTime?
  emailVerifiedAt        DateTime?
  refreshTokenHash       String?
  refreshTokenExpiresAt  DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  memberships            WorkspaceMember[]
  createdWorkspaces      Workspace[]              @relation("WorkspaceCreatedBy")
  invitations            Invitation[]             @relation("InvitationInvitedBy")
  bookings               Booking[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens    PasswordResetToken[]
  workspacePreferences   UserWorkspacePreference[]
  operationLogs          OperationLog[]
  rateLimitSuspensions   RateLimitSuspension[]
}

model Workspace {
  id              String            @id @default(uuid()) @db.Uuid
  name            String
  timezone        String            @default("UTC")
  scheduleStartHour Int             @default(8)
  scheduleEndHour Int               @default(18)
  status          WorkspaceStatus   @default(ACTIVE)
  cancelledAt     DateTime?
  createdByUserId String            @db.Uuid
  createdByUser   User              @relation("WorkspaceCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  members         WorkspaceMember[]
  invitations     Invitation[]
  rooms           Room[]
  bookings        Booking[]
  userPreferences UserWorkspacePreference[]
  scheduleVersions WorkspaceScheduleVersion[]

  @@index([createdByUserId])
  @@index([status, name])
}

model UserWorkspacePreference {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  workspaceId String   @db.Uuid
  sortOrder  Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId, sortOrder])
  @@index([workspaceId])
}

model WorkspaceMember {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @db.Uuid
  userId      String           @db.Uuid
  role        WorkspaceRole    @default(MEMBER)
  status      MembershipStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, status])
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  workspaceId    String           @db.Uuid
  email          String
  tokenHash      String
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  invitedByUserId String          @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedByUser  User             @relation("InvitationInvitedBy", fields: [invitedByUserId], references: [id])

  @@index([workspaceId, email, status])
}

model Room {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  name        String
  description String?
  status      RoomStatus @default(ACTIVE)
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([workspaceId])
  @@index([workspaceId, status, name])
}

model Booking {
  id             String            @id @default(uuid()) @db.Uuid
  workspaceId    String            @db.Uuid
  roomId         String            @db.Uuid
  createdByUserId String           @db.Uuid
  startAt        DateTime          @db.Timestamptz(6)
  endAt          DateTime          @db.Timestamptz(6)
  timeRange      Unsupported("tstzrange")? @map("timeRange")
  subject        String
  criticality    BookingCriticality @default(MEDIUM)
  status         BookingStatus      @default(ACTIVE)
  cancelledAt    DateTime?
  cancellationReason BookingCancellationReason?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  room           Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdByUser  User               @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([roomId, startAt])
  @@index([workspaceId, status])
}

model WorkspaceScheduleVersion {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String    @db.Uuid
  timezone          String
  scheduleStartHour Int
  scheduleEndHour   Int
  effectiveFrom     DateTime  @db.Timestamptz(6)
  createdAt         DateTime  @default(now())
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, effectiveFrom])
  @@index([workspaceId, effectiveFrom])
}

model OperationLog {
  id            String                 @id @default(uuid()) @db.Uuid
  operationType RateLimitOperationType
  ipAddress     String?
  userId        String?                @db.Uuid
  createdAt     DateTime               @default(now()) @db.Timestamptz(6)
  user          User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([operationType, ipAddress, createdAt])
  @@index([operationType, userId, createdAt])
}

model RateLimitSuspension {
  id            String               @id @default(uuid()) @db.Uuid
  subjectType   RateLimitSubjectType
  operationType RateLimitOperationType
  ipAddress     String?
  userId        String?              @db.Uuid
  suspendedAt   DateTime             @default(now()) @db.Timestamptz(6)
  expiresAt     DateTime             @db.Timestamptz(6)
  user          User?                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([subjectType, ipAddress, expiresAt])
  @@index([subjectType, userId, expiresAt])
}

model EmailVerificationToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, consumedAt])
}

model PasswordResetToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, consumedAt])
}
